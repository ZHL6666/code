// 借用检查测试示例

fn main() {
    // 测试 1: 基本可变借用
    let mut x = 10;
    let r1 = &mut x;
    // 解引用操作暂不支持，直接打印
    
    // 测试 2: 双重可变借用 (应失败)
    // let r2 = &mut x;  // 这行应该报错
    
    // 测试 3: 多个不可变借用
    let y = 5;
    let s1 = &y;
    let s2 = &y;
    // let s3 = &mut y;  // 这行应该报错：存在不可变借用时不能可变借用
    
    println(x);
    println(y);
}
